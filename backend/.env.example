PORT=4000
CLIENT_URL=http://localhost:5173
JWT_SECRET=replace-with-strong-secret
JWT_EXPIRES_IN=8h

# Local MySQL (or set MYSQL_URL instead)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=discopain
DB_USER=root
DB_PASSWORD=root

# Railway / managed MySQL: use the variables from the MySQL service tab (Reference / Connect),
# or paste MYSQL_URL. Do not reuse your laptop XAMPP root password unless that server allows remote hosts.
# MYSQL_URL=mysql://USER:PASSWORD@HOST:PORT/DATABASE
# MYSQL_SSL=true
